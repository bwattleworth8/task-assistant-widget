{
  "name": "work-slate",
  "version": "0.1.0",
  "description": "Your daily console for planning, focus, and work clarity.",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "start": "node scripts/start-electron.js",
    "icons": "node scripts/generate-icons.js",
    "check": "node --check scripts/start-electron.js && node --check scripts/generate-icons.js && node --check src/main.js && node --check src/preload.js && node --check src/settingsStore.js && node --check src/trelloClient.js && node --check src/renderer/app.js",
    "pack": "npm run icons && electron-builder --dir",
    "dist": "npm run icons && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.local.work-slate",
    "productName": "Work Slate",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "artifactName": "${productName} Setup ${version}.${ext}",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "Work Slate"
    }
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.8.1"
  }
}
